# Anthropic API Key
# Used for Claude Haiku 4.5 (query processing) and Claude Sonnet 4.6 (answer synthesis).
# Get it here: https://console.anthropic.com/
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Serper API Key
# Used for the Web Retriever pipeline to fetch Google search results.
# Get it here: https://serper.dev/
SERPER_API_KEY="your_serper_api_key_here"

# Jina Reader API Key
# Used for the Content Extractor pipeline to parse and clean the web pages.
# Get it here: https://jina.ai/reader/
JINA_API_KEY="your_jina_api_key_here"
